import 'package:flutter/material.dart';

void main() => runApp(StudyMasterApp());

class StudyMasterApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: 'تطبيق دراستي الشامل',
      theme: ThemeData(
        primarySwatch: Colors.teal,
        fontFamily: 'Arial', // يفضل استخدام خط يدعم العربية
      ),
      home: MainNavigationPage(),
    );
  }
}

class MainNavigationPage extends StatefulWidget {
  @override
  _MainNavigationPageState createState() => _MainNavigationPageState();
}

class _MainNavigationPageState extends State<MainNavigationPage> {
  int _currentIndex = 0;
  final List<Widget> _pages = [StudyTasksPage(), LessonsLibraryPage()];

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: _pages[_currentIndex],
      bottomNavigationBar: BottomNavigationBar(
        currentIndex: _currentIndex,
        onTap: (index) => setState(() => _currentIndex = index),
        items: [
          BottomNavigationBarItem(icon: Icon(Icons.check_circle), label: 'مهامي'),
          BottomNavigationBarItem(icon: Icon(Icons.library_books), label: 'الدروس'),
        ],
      ),
    );
  }
}

// --- قسم المهام الدراسية ---
class StudyTasksPage extends StatefulWidget {
  @override
  _StudyTasksPageState createState() => _StudyTasksPageState();
}

class _StudyTasksPageState extends State<StudyTasksPage> {
  List<String> tasks = ["مراجعة مادة الرياضيات", "تحضير درس الفيزياء"];
  TextEditingController controller = TextEditingController();

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text('قائمة مهامي الدراسية')),
      body: Column(
        children: [
          Padding(
            padding: const EdgeInsets.all(12.0),
            child: Row(
              children: [
                Expanded(child: TextField(controller: controller, decoration: InputDecoration(hintText: 'أضف مهمة جديدة...'))),
                IconButton(icon: Icon(Icons.add_box, color: Colors.teal), onPressed: () {
                  if (controller.text.isNotEmpty) {
                    setState(() { tasks.add(controller.text); controller.clear(); });
                  }
                })
              ],
            ),
          ),
          Expanded(
            child: ListView.builder(
              itemCount: tasks.length,
              itemBuilder: (context, i) => ListTile(
                leading: Icon(Icons.book_outlined),
                title: Text(tasks[i]),
                trailing: IconButton(icon: Icon(Icons.delete_outline, color: Colors.red), onPressed: () => setState(() => tasks.removeAt(i))),
              ),
            ),
          )
        ],
      ),
    );
  }
}

// --- قسم مكتبة الدروس لجميع السنوات ---
class LessonsLibraryPage extends StatelessWidget {
  final Map<String, List<String>> data = {
    "السنة الأولى ثانوي": ["رياضيات: الدوال الأساسية", "فيزياء: الميكانيك", "عربية: تحليل نصوص"],
    "السنة الثانية ثانوي": ["رياضيات: الاحتمالات", "علوم: الخلية والطاقة", "إنجليزية: Grammar"],
    "السنة الثالثة ثانوي (بكالوريا)": ["فلسفة: السؤال العلمي", "رياضيات: الأعداد المركبة", "تاريخ: الثورة الجزائرية"],
  };

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text('مكتبة الدروس الشاملة')),
      body: ListView.builder(
        itemCount: data.keys.length,
        itemBuilder: (context, index) {
          String year = data.keys.elementAt(index);
          return ExpansionTile(
            leading: Icon(Icons.folder, color: Colors.orange),
            title: Text(year, style: TextStyle(fontWeight: FontWeight.bold)),
            children: data[year]!.map((lesson) => ListTile(
              title: Text(lesson),
              leading: Icon(Icons.picture_as_pdf, color: Colors.redAccent),
              onTap: () {
                // هنا نضع رابط الدرس المستقبلي
                ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text("جاري فتح: $lesson")));
              },
            )).toList(),
          );
        },
      ),
    );
  }
}
